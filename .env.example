# Skyfall AI Agents v7.0 - Environment Configuration

# Server Settings
SKYFALL_PORT=8888
DEBUG_MODE=0
COMMAND_TIMEOUT=300

# Authentication
SKYFALL_AUTH_ENABLED=false
SKYFALL_KEY_FILE=data/api_keys.json

# Performance & Caching
SKYFALL_CACHE_SIZE=1000
SKYFALL_CACHE_TTL=3600

# AI Backend API Keys (MANDATORY for AI Agents)
OPENROUTER_API_KEY=
GOOGLE_API_KEY=your_google_gemini_key_here
NVIDIA_API_KEY=

# AI Model Configuration
SKYFALL_MODEL=openai/gpt-4o  # or google/gemini-pro-1.5, anthropic/claude-3-opus, etc.

# Tool Paths (Optional if tools are in PATH)
# NMAP_PATH=C:\Program Files (x86)\Nmap\nmap.exe

# Notification Channels (Pro Features)
DISCORD_WEBHOOK_URL=your_discord_webhook_here
TELEGRAM_BOT_TOKEN=your_telegram_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
